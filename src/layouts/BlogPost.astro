---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
const dateStr = new Date(frontmatter.date).toLocaleDateString('tr-TR', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---
<BaseLayout title={`${frontmatter.title} — Kaan Gümele`} description={frontmatter.description} canonical={frontmatter.canonical}>
  <article class="container">
    <header class="post-header">
      <p class="label">yazılar</p>
      <h1>{frontmatter.title}</h1>
      <div class="meta">
        <time>{dateStr}</time>
        {frontmatter.tags && <span class="tags">{frontmatter.tags.join(' · ')}</span>}
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
    <div class="back">
      <a href="/blog">← Tüm yazılar</a>
    </div>
  </article>
</BaseLayout>

<style>
article { padding: 64px 24px 80px; }
.post-header { margin-bottom: 40px; }
.post-header h1 { margin: 8px 0 12px; font-size: clamp(1.375rem, 4vw, 1.75rem); }
.meta {
  display: flex;
  gap: 12px;
  align-items: center;
  font-family: var(--mono);
  font-size: 0.75rem;
  color: var(--muted);
  flex-wrap: wrap;
}
.tags { color: var(--primary); }

.prose { border-top: 1px solid var(--border); padding-top: 32px; }
.prose :global(h2) { margin: 2em 0 0.75em; }
.prose :global(h3) { margin: 1.5em 0 0.5em; }
.prose :global(p)  { margin-bottom: 1.25em; }
.prose :global(ul), .prose :global(ol) { padding-left: 1.5em; margin-bottom: 1.25em; }
.prose :global(li) { margin-bottom: 0.35em; }
.prose :global(blockquote) {
  border-left: 3px solid var(--primary);
  padding-left: 16px;
  color: var(--muted);
  font-style: italic;
  margin: 1.5em 0;
}

.back { margin-top: 56px; padding-top: 24px; border-top: 1px solid var(--border); }
.back a { font-family: var(--mono); font-size: 0.875rem; color: var(--muted); }
.back a:hover { color: var(--primary); text-decoration: none; opacity: 1; }
</style>
