---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    name: 'autonomous_browser_ai_agent',
    url: 'https://github.com/Kaangml/autonomous_browser_ai_agent',
    desc: 'Google Maps için LLM destekli otonom tarama ajanı. Manuel QA\'yı ~%80 azalttı. LangGraph + AWS Bedrock + Playwright.',
  },
  {
    name: 'orchestration_agents',
    url: 'https://github.com/Kaangml/orchestration_agents',
    desc: '5-agent hiyerarşik orkestrasyon sistemi. Doğal dil girdisini görev planına dönüştürür. Orchestrator → Planner → Feedback → Execution.',
  },
  {
    name: 'browseruse_ai_agent',
    url: 'https://github.com/Kaangml/browseruse_ai_agent',
    desc: 'FastAPI tabanlı browser otomasyon servisi. Multi-LLM desteği, Docker-ready, structured logging. browser-use üzerine inşa servis katmanı.',
  },
  {
    name: 'swin-image-classifier',
    url: 'https://github.com/Kaangml/swin-image-classifier',
    desc: 'Swin Transformer V2 ile görüntü sınıflandırma. Gradio arayüzü, Docker deploy, model quantization desteği.',
  },
  {
    name: 'live_translate_speech',
    url: 'https://github.com/Kaangml/live_translate_speech',
    desc: 'Deepgram STT/TTS ile gerçek zamanlı P2P ses çeviri sistemi. Konuşulanı anında başka dile çevirir.',
  },
  {
    name: 'polygons_hunter',
    url: 'https://github.com/Kaangml/polygons_hunter',
    desc: 'Koordinat → polygon eşleştirme REST API. QuadKey indeksleme + ray-casting algoritması. Geospatial veri işleme.',
  },
  {
    name: 'autogen_agent',
    url: 'https://github.com/Kaangml/autogen_agent',
    desc: 'Autogen ile modüler AI ajan framework\'ü. Gemini & Ollama desteği, Docker-ready deployment.',
  },
  {
    name: 'RAG-LLM',
    url: 'https://github.com/Kaangml/RAG-LLM',
    desc: 'Chroma DB + Gemini ile RAG pipeline. Vektör tabanlı belge arama ve LLM entegrasyonu.',
  },
];

const postModules = import.meta.glob('./blog/*.md', { eager: true });
const recentPosts = Object.entries(postModules)
  .map(([path, mod]) => ({
    slug: path.replace('./blog/', '').replace('.md', ''),
    title: mod.frontmatter.title,
    date: mod.frontmatter.date,
  }))
  .sort((a, b) => new Date(b.date) - new Date(a.date))
  .slice(0, 3);
---
<BaseLayout>
  <div class="container">

    <section class="hero">
      <h1><span class="prefix">//</span> kaan gümele</h1>
      <p class="role">Applied AI Engineer & Data Scientist · İstanbul</p>
      <p class="bio">
        Otonom ajanlar, RAG pipeline'ları ve production-grade vision modelleri dahil
        uçtan uca ML/AI sistemleri inşa ediyorum.
        <a href="https://mapindata.com" target="_blank" rel="noopener">Mapin Data</a>'da
        big data, LLM ajanları ve computer vision üzerinde çalışıyorum.
        Tıbbi AI alanında yayınlanmış araştırmacı.
      </p>
    </section>

    <hr />

    <section>
      <p class="label">projeler</p>
      <dl class="project-list">
        {projects.map(p => (
          <div class="project-item">
            <dt><a href={p.url} target="_blank" rel="noopener">{p.name}</a></dt>
            <dd>{p.desc}</dd>
          </div>
        ))}
      </dl>
      <a href="https://github.com/Kaangml" class="more-link" target="_blank" rel="noopener">
        github.com/Kaangml →
      </a>
    </section>

    {recentPosts.length > 0 && (
      <>
        <hr />
        <section>
          <p class="label">son yazılar</p>
          <ul class="post-list">
            {recentPosts.map(post => (
              <li>
                <a href={`/blog/${post.slug}`}>{post.title}</a>
                <time>{new Date(post.date).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long' })}</time>
              </li>
            ))}
          </ul>
          <a href="/blog" class="more-link">tüm yazılar →</a>
        </section>
      </>
    )}

  </div>
</BaseLayout>

<style>
.container { padding-top: 72px; padding-bottom: 80px; }

.hero h1 {
  font-size: clamp(1.75rem, 5vw, 2.25rem);
  letter-spacing: -0.03em;
  margin-bottom: 6px;
}
.prefix { color: var(--primary); margin-right: 2px; }
.role {
  font-family: var(--mono);
  font-size: 0.8125rem;
  color: var(--muted);
  margin-bottom: 24px;
  letter-spacing: 0.02em;
}
.bio {
  font-size: 1.0625rem;
  line-height: 1.8;
  color: var(--text);
  max-width: 560px;
  margin: 0;
}

.project-list { display: flex; flex-direction: column; }
.project-item {
  display: grid;
  grid-template-columns: 230px 1fr;
  gap: 8px 24px;
  padding: 14px 0;
  border-bottom: 1px solid var(--border);
  align-items: baseline;
}
.project-item:first-child { border-top: 1px solid var(--border); }
.project-item dt { font-family: var(--mono); font-size: 0.875rem; font-weight: 600; }
.project-item dt a { color: var(--bright); }
.project-item dt a:hover { color: var(--primary); text-decoration: none; opacity: 1; }
.project-item dd { font-size: 0.9375rem; color: var(--text); margin: 0; line-height: 1.6; }

.post-list { list-style: none; }
.post-list li {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 16px;
  padding: 12px 0;
  border-bottom: 1px solid var(--border);
  flex-wrap: wrap;
}
.post-list li:first-child { border-top: 1px solid var(--border); }
.post-list a { font-size: 0.9375rem; color: var(--bright); }
.post-list a:hover { color: var(--primary); text-decoration: none; opacity: 1; }
.post-list time { font-family: var(--mono); font-size: 0.75rem; color: var(--muted); white-space: nowrap; }

.more-link {
  display: inline-block;
  margin-top: 16px;
  font-family: var(--mono);
  font-size: 0.8125rem;
  color: var(--muted);
}
.more-link:hover { color: var(--primary); text-decoration: none; opacity: 1; }

@media (max-width: 520px) {
  .project-item { grid-template-columns: 1fr; gap: 4px; }
}
</style>
