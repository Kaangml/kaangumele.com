---
import BaseLayout from '../../layouts/BaseLayout.astro';

const postModules = import.meta.glob('./*.md', { eager: true });
const posts = Object.entries(postModules)
  .map(([path, mod]) => ({
    slug: path.replace('./', '').replace('.md', ''),
    title: mod.frontmatter.title,
    date: mod.frontmatter.date,
    description: mod.frontmatter.description,
    tags: mod.frontmatter.tags || [],
  }))
  .sort((a, b) => new Date(b.date) - new Date(a.date));
---
<BaseLayout
  title="Yazılar — Kaan Gümele"
  description="Docker, AI, AWS ve veri mühendisliği üzerine teknik yazılar."
>
  <div class="container">
    <p class="label">yazılar</p>
    <h1>Yazılar</h1>
    <p class="intro">Docker, LLM, Computer Vision ve AWS üzerine teknik notlar ve eğitim materyalleri.</p>

    {posts.length === 0 ? (
      <p class="empty">Henüz yazı yok.</p>
    ) : (
      <ul class="post-list">
        {posts.map(post => (
          <li>
            <a href={`/blog/${post.slug}`}>
              <span class="post-title">{post.title}</span>
              <span class="post-meta">
                <time>{new Date(post.date).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long' })}</time>
                {post.tags.length > 0 && <span class="tags">{post.tags.join(' · ')}</span>}
              </span>
              {post.description && <span class="post-desc">{post.description}</span>}
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>

<style>
.container { padding-top: 64px; padding-bottom: 80px; }
h1 { margin: 8px 0 16px; }
.intro { color: var(--text); font-size: 0.9375rem; margin-bottom: 40px; margin-top: 0; }
.empty { color: var(--muted); font-family: var(--mono); font-size: 0.875rem; }

.post-list { list-style: none; }
.post-list li { border-bottom: 1px solid var(--border); }
.post-list li:first-child { border-top: 1px solid var(--border); }
.post-list a { display: block; padding: 18px 0; color: inherit; text-decoration: none; }
.post-list a:hover .post-title { color: var(--primary); }
.post-title {
  display: block;
  font-family: var(--mono);
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--bright);
  margin-bottom: 4px;
  transition: color 0.15s;
}
.post-meta {
  display: flex;
  gap: 10px;
  font-family: var(--mono);
  font-size: 0.75rem;
  color: var(--muted);
  margin-bottom: 4px;
}
.tags { color: var(--primary); }
.post-desc { display: block; font-size: 0.875rem; color: var(--text); line-height: 1.55; }
</style>
